# ──────────────────────────────────────────────
# Database (PostgreSQL via Supabase / Hostinger)
# ──────────────────────────────────────────────
# DATABASE_URL — Pooled connection (used by Prisma at runtime).
#                Uses pgBouncer-compatible port 6543.
#                Example: "postgresql://user:password@pooler-host:6543/dbname?pgbouncer=true"
DATABASE_URL="postgresql://user:password@pooler-host:6543/dbname?pgbouncer=true"

# DIRECT_URL  — Direct connection to PostgreSQL (used by Prisma for migrations only).
#               Bypasses pgBouncer on port 5432.
#               Required for "prisma migrate deploy" to work.
#               Example: "postgresql://user:password@direct-host:5432/dbname"
DIRECT_URL="postgresql://user:password@direct-host:5432/dbname"

# ──────────────────────────────────────────────
# Auth (Auth.js / NextAuth v5)
# ──────────────────────────────────────────────
# Generate a secure secret:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Full application URL (e.g. https://ramsa-erp.com)
AUTH_URL=

# ──────────────────────────────────────────────
# Seed (first SYSTEM_ADMIN user)
# ──────────────────────────────────────────────
# Used by: npx tsx prisma/seed.ts
# Run once after prisma migrate deploy to create the initial admin account.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# Supabase (optional, for storage / realtime)
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
